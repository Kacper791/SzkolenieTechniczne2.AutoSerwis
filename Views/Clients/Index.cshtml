@model List<SzkolenieTechniczne2.AutoSerwis.Domain.Query.Dtos.ClientDto>
@{
    ViewData["Title"] = "Lista klientów";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>🚗 Lista klientów</h2>
    <a asp-action="Create" class="btn btn-success">
        <i class="bi bi-plus-circle"></i> Dodaj klienta
    </a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Brak klientów w bazie danych.</div>
}
else
{
    <table class="table table-striped table-hover table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nazwa klienta</th>
                <th class="text-center">Akcje</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var client in Model)
            {
                <tr>
                    <td>@client.Id</td>
                    <td>@client.Name</td>
                    <td class="text-center">
                        <a asp-action="Details" asp-route-id="@client.Id" class="btn btn-sm btn-primary">
                            Szczegóły
                        </a>
                        <form asp-action="Delete" asp-route-id="@client.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Czy na pewno usunąć klienta @client.Name?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}