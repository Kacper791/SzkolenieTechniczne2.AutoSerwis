@model IEnumerable<SzkolenieTechniczne2.AutoSerwis.Domain.Query.Dtos.ClientDto>
@{
    ViewData["Title"] = "Lista klientów";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>📋 Lista klientów</h2>
    <a asp-action="Create" class="btn btn-success fw-bold">Dodaj klienta</a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info shadow-sm" role="alert">
        Brak klientów w bazie danych.
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Nazwa klienta</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.Name</td>
                            <td class="text-end">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-2">Szczegóły</a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tego klienta?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Usuń</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}